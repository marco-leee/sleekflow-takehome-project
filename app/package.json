{
  "name": "app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "prepare": "husky",
    "typecheck": "turbo typecheck"
  },
  "packageManager": "bun@1.3.9",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css}": "biome check --write --no-errors-on-unmatched ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": ["apps/*", "packages/*"]
}
